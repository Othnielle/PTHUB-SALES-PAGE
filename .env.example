# Copy this file to .env for local testing only.
# On Railway/Render, set these in the dashboard's Environment Variables
# section instead — never commit a real .env file.

# From Paystack Dashboard → Settings → API Keys & Webhooks
# Roll/regenerate immediately if this ever leaks (chat, GitHub, screenshots, etc).
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Generate your own — never reuse an example value.
# Run:  openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET=replace_with_a_random_64_char_hex_string

# Where "Resend Links" / fallback error pages tell buyers to email
SUPPORT_EMAIL=pthub413@gmail.com

# Railway/Render set PORT automatically — only needed for local runs
PORT=3000
