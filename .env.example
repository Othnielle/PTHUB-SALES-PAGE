# ============================================================
# VIBE & LAUNCH — Environment Variables
# ============================================================
# HOW TO USE:
#   Local dev: copy this file to .env and fill in real values
#   Railway: add each variable in your service → Variables tab
#   NEVER commit a real .env file to GitHub
# ============================================================

# Your Paystack SECRET key (sk_live_... or sk_test_... for testing)
# Get it: Paystack Dashboard → Settings → API Keys & Webhooks
# If this is missing or wrong, NO payment can ever be verified.
PAYSTACK_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_REAL_SECRET_KEY

# Random signing secret for download tokens
# Already generated for you: da78eb5869ca9e1ea98faf238df877a6caebe4ddbc8c478d78f5afc729549351
# Or generate a new one: openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET=da78eb5869ca9e1ea98faf238df877a6caebe4ddbc8c478d78f5afc729549351

# Support email shown on error pages
SUPPORT_EMAIL=pthub413@gmail.com

# Port — Railway sets this automatically, only needed for local dev
PORT=3000
